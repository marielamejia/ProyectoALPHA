<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="client.GUIJuego">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="5a8f5" binding="panelTitulo" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="38088" class="javax.swing.JLabel" binding="labelTitulo">
            <constraints/>
            <properties>
              <text value="¡Pégale al monstruo!"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="16094" binding="panelBotones" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="ffe70" class="javax.swing.JButton" binding="buttonIniciarPartida">
            <constraints/>
            <properties>
              <label value="Iniciar "/>
              <text value="Iniciar "/>
            </properties>
          </component>
          <component id="1cb9" class="javax.swing.JButton" binding="buttonSalirPartida">
            <constraints/>
            <properties>
              <label value="Salir"/>
              <text value="Salir"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="17eb5" binding="panelJuego" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="1d6fe" binding="panelEstado" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="20" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints border-constraint="North"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="861a0" class="javax.swing.JLabel" binding="labelJugador">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Jugador: "/>
                </properties>
              </component>
              <component id="9d7db" class="javax.swing.JLabel" binding="labelMonstGolpeados">
                <constraints>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Monstruos golpeados:"/>
                </properties>
              </component>
              <component id="c90be" class="javax.swing.JLabel" binding="labelEstado">
                <constraints>
                  <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Estado:"/>
                </properties>
              </component>
            </children>
          </grid>
          <grid id="eafe7" binding="panelTablero" layout-manager="GridLayoutManager" row-count="3" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
