      <grid id="bd071" binding="panelJugadores" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="East"/>
        <properties>
          <alignmentX value="0.5"/>
          <preferredSize width="100" height="-1"/>
        </properties>
        <border type="none"/>
        <children>
          <scrollpane id="7703d" binding="scrollPaneJugadores">
            <constraints border-constraint="Center"/>
